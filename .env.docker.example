# Copy this file to ".env" next to docker-compose.yml on your VPS and fill
# in real values. This .env is read by `docker compose` itself (not by the
# app code) to fill in the ${VAR} placeholders in docker-compose.yml.

# Postgres (the "db" container) — pick any values, this is a new database
POSTGRES_USER=educrm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=educrm

# From your own Clerk.com project (Configure -> API Keys)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Any long random string
SESSION_SECRET=change-me-too
